import org.code.neighborhood.*;

public class PainterPlus extends Painter {
  public void turnRight() {
    turnLeft();
    turnLeft();
    turnLeft();
  }
  public void moveTurnPaint(String color) {
    move();
    turnLeft();
    turnLeft();
    turnLeft();
    paint(color);
    move();
    paint(color);
  }
  
}
